AWS_REGION=ap-northeast-2
S3_BUCKET=abuddy-data
DYNAMODB_QUESTIONS_TABLE=abuddy-questions
DYNAMODB_SCHEDULE_TABLE=abuddy-schedule
BEDROCK_MODEL_ID=anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_SMART_MODEL_ID=anthropic.claude-sonnet-4-6

# setup_aws.py 실행 후 출력되는 값을 복사하세요
COGNITO_USER_POOL_ID=ap-northeast-2_XXXXXXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_DOMAIN=abuddy-xxxx.auth.ap-northeast-2.amazoncognito.com
APP_BASE_URL=http://YOUR_EC2_IP

# fetch_concept_docs.py 실행 시 필요 (https://app.tavily.com)
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxx
